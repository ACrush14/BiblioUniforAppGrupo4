<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F7">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7F7">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#87DEDE">

                <TextView
                    android:id="@+id/btnFechar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1B3434"
                    android:layout_alignParentEnd="true"
                    android:layout_margin="16dp" />

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/bg_circle"
                    android:padding="10dp"
                    android:src="@mipmap/ic_launcher"/>
            </RelativeLayout>

            <!-- CONTEÚDO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="531dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TÍTULO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Redefinir senha"
                    android:textColor="#1B3434"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- NOVA SENHA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nova senha"
                    android:textColor="#415E5E"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editNovaSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite sua nova senha"
                    android:inputType="textPassword"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/textErroSenha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#E53935"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- CONFIRMAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Confirmar senha"
                    android:textColor="#415E5E"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editConfirmarSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_input"
                    android:hint="Repita a senha"
                    android:inputType="textPassword"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/textErroConfirmar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#E53935"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- REGRAS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="A senha deve conter:\n• mínimo 8 caracteres\n• pelo menos 1 número\n• pelo menos 1 letra maiúscula"
                    android:textColor="#758989"
                    android:textSize="13sp" />

                <!-- BOTÃO -->
                <Button
                    android:id="@+id/buttonSalvar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="#87DEDE"
                    android:text="Salvar alterações"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BARRA -->
    <LinearLayout
        android:id="@+id/bottomNavigationUsuario"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_view"
            app:tint="#1B3434" />

        <ImageView
            android:id="@+id/navBusca"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navFavoritos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navLivros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#A0A0A0" />

    </LinearLayout>

</LinearLayout>