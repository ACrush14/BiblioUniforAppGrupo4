<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F7">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7F7">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#6EC1C3"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitações"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_centerInParent="true"/>

                <TextView
                    android:id="@+id/btnFechar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="10dp"/>
            </RelativeLayout>

            <!-- LISTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ITEM 1 -->
                <LinearLayout
                    android:id="@+id/itemSolicitacao1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_rounded"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:src="@android:drawable/sym_def_app_icon"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_input_rounded"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Livro Exemplo 1"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1B3434"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="por Autor Exemplo"
                            android:textSize="12sp"
                            android:textColor="#415E5E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="01 jan. 2024"
                            android:textSize="12sp"
                            android:textColor="#758989"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- ITEM 2 -->
                <LinearLayout
                    android:id="@+id/itemSolicitacao2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input_rounded"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:src="@android:drawable/sym_def_app_icon"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_input_rounded"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Livro Exemplo 2"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1B3434"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="por Outro Autor"
                            android:textSize="12sp"
                            android:textColor="#415E5E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="02 fev. 2024"
                            android:textSize="12sp"
                            android:textColor="#758989"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 🔥 BARRA ADM -->
    <LinearLayout
        android:id="@+id/bottomNavigationADM"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_today"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navUsuarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navSolicitacoes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            app:tint="#1B3434" />

        <ImageView
            android:id="@+id/navAjuda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_help"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navLivrosADM"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#A0A0A0" />

    </LinearLayout>

</LinearLayout>