<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="#6EC1C3"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnConfigAdm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_manage"
            android:layout_alignParentStart="true"
            android:layout_marginTop="32dp"
            app:tint="#FFFFFF"
            android:contentDescription="Configurações ADM" />

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="32dp"
            android:src="@drawable/perfil_exemplo"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle"
            android:clipToOutline="true"/>

        <TextView
            android:id="@+id/txtBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem vindo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp"/>

        <TextView
            android:id="@+id/txtDashboardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DASHBOARD DE ADM"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_below="@id/txtBemVindo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp" />

    </RelativeLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD 1: USUARIOS E ALUGUEIS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Usuários" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5.785" android:textSize="28sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginTop="8dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alugueis" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="342" android:textSize="28sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTelaCrud"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Tela CRUD"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2: ANALISE DE ALUGUEIS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Análise de Aluguéis"
                    android:textStyle="bold"
                    android:textColor="#415E5E"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Março 2026 - 342"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fevereiro 2026 - 294"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Janeiro 2026 - 648"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver Aluguéis"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6CB6B3"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- ATRASOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Análise de Alugueis"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Março 2026" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="342" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fevereiro 2026" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="294" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Janeiro 2026" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="648" android:textSize="22sp" android:textStyle="bold" android:textColor="#000000"/>
                    </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver todos os atrasos"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6CB6B3"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- CADASTROS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cadastros para confirmar"
                    android:textStyle="bold"
                    android:textColor="#415E5E"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jéssica Amaral"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jeferson da Rocha"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roberto de Souza"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver cadastros"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6CB6B3"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- SOLICITAÇÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atrasos"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O Jardim das Ilusões"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vozes do Deserto"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Um Homem Chamado Ove"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerSolicitacoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver solicitações"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6CB6B3"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- RENOVAÇÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitações/Renovações aluguel"
                    android:textStyle="bold"
                    android:textColor="#415E5E"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cícero Correia - Pessoas Ansiosas - 5 maio"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver renovações"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6CB6B3"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM PADRONIZADA -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_adm" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
