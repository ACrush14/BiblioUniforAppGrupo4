<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER COM FOTO CENTRAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#6EC1C3"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgPerfilLivro"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_circle"
                android:contentDescription="Imagem de perfil"
                android:padding="10dp"
                android:src="@android:drawable/sym_def_app_icon" />

        </LinearLayout>

        <!-- FORMULÁRIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título:"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input"
                android:hint="Título..."
                android:padding="14dp"
                android:textColor="#1B3434"
                android:textColorHint="#999999"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Autor:"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etAutor"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input"
                android:hint="Autor..."
                android:padding="14dp"
                android:textColor="#1B3434"
                android:textColorHint="#999999"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código ISBN:"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etISBN"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input"
                android:hint="Código ISBN..."
                android:inputType="number"
                android:padding="14dp"
                android:textColor="#1B3434"
                android:textColorHint="#999999"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data de publicação do Livro:"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etData"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input"
                android:hint="Data..."
                android:padding="14dp"
                android:textColor="#1B3434"
                android:textColorHint="#999999"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantidade de Exemplares"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etQuantidade"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input"
                android:hint="Quantidade de Exemplares..."
                android:inputType="number"
                android:padding="14dp"
                android:textColor="#1B3434"
                android:textColorHint="#999999"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnContinuar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_botao_verde"
                android:text="Editar mais informações"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvErro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Preencha todos os campos para continuar"
                android:textColor="#D65252"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="30dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>