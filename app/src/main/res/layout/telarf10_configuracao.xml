<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F7">

    <!-- SCROLL ORIGINAL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#87DEDE"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageIcon2"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:contentDescription="Ícone do aplicativo"
                    android:src="@mipmap/ic_launcher" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seu Perfil"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- CONTEÚDO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/editNome"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Seu nome"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/editUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Usuário"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/editBio"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="Digite sua bio"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="10dp"
                    android:padding="12dp"
                    android:gravity="top" />

                <EditText
                    android:id="@+id/editSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="******"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:layout_marginBottom="20dp"
                    android:padding="12dp" />

                <!-- BOTÃO REDEFINIR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRedefinirSenha"
                    android:layout_width="match_parent"
                    android:layout_height="59dp"
                    android:layout_marginBottom="12dp"
                    android:text="Redefinir Senha"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#87DEDE"
                    app:cornerRadius="30dp"
                    app:elevation="6dp" />

                <!-- BOTÃO VOLTAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="match_parent"
                    android:layout_height="59dp"
                    android:layout_marginBottom="12dp"
                    android:text="Voltar"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#415E5E"
                    app:cornerRadius="30dp"
                    app:elevation="6dp" />

                <!-- BOTÃO APAGAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApagarConta"
                    android:layout_width="match_parent"
                    android:layout_height="59dp"
                    android:text="Apagar Conta"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#E53935"
                    app:cornerRadius="30dp"
                    app:elevation="6dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 🔥 BARRA DE NAVEGAÇÃO CORRIGIDA -->
    <LinearLayout
        android:id="@+id/bottomNavigationUsuario"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_view"
            app:tint="#1B3434" />

        <ImageView
            android:id="@+id/navBusca"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navFavoritos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navLivros"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#A0A0A0" />

    </LinearLayout>

</LinearLayout>