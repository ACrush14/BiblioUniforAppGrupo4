<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#6EC1C3"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:src="@drawable/perfil_exemplo"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle"
            android:clipToOutline="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tela de CRUD"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"
            android:layout_marginTop="40dp"/>
    </RelativeLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCriarMidia"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Criar Mídia"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerificarMidia"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Verificar Mídia"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGerenciarUsuario"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Gerenciar usuário"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMudarPermissao"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Mudar permissão de usuário"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApagarUsuario"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Apagar Usuário"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#D65B5B"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApagarMidia"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Apagar Mídia"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#D65B5B"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM PADRONIZADA -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_adm" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
