<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#87DEDE"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Ícone do app" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acesse sua Conta"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- CONTEÚDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/textTituloConfirmacaoCodigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="@string/titulo_redefinir"
                android:textColor="#415E5E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDescricaoConfirmacaoCodigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="@string/descricao_confirmacao_codigo"
                android:textColor="#415E5E" />

            <EditText
                android:id="@+id/editCodigo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/digite_codigo"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textErro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/erro_codigo"
                android:textColor="#F44336"
                android:layout_marginBottom="12dp" />

            <!-- BOTÃO ENVIAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnviarCodigo"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="@string/btn_enviar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                app:backgroundTint="#87DEDE"
                app:cornerRadius="30dp"
                app:elevation="6dp" />

            <!-- REENVIAR -->
            <TextView
                android:id="@+id/textReenviarCodigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reenviar"
                android:gravity="center"
                android:textColor="#6CB6B3"
                android:layout_marginBottom="20dp" />

            <!-- VOLTAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoltarTelaValidacaoCodigo"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="@string/voltar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#415E5E"
                app:cornerRadius="30dp"
                app:elevation="6dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>