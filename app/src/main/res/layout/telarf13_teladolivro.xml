<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🔷 HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/biblio_cyan"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgCapaLivroDetalhe"
                    android:layout_width="120dp"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/o_alienista_capa" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:id="@+id/txtTituloLivroDetalhe"
                        android:layout_width="130dp"
                        android:layout_height="24dp"
                        android:text="Titulo do livro"
                        android:textColor="@android:color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtAutorLivroDetalhe"
                        android:layout_width="120dp"
                        android:layout_height="20dp"
                        android:layout_marginBottom="8dp"
                        android:text="Nome do autor(a)"
                        android:textColor="@android:color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Lista de desejos"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/biblio_dark"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sua livraria"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/biblio_dark"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 🔘 BOTÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="222dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- linha 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Não lido"
                        app:backgroundTint="@color/biblio_cyan" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="Lendo"
                        app:backgroundTint="@color/biblio_cyan" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="Lido"
                        app:backgroundTint="@color/biblio_cyan" />
                </LinearLayout>

                <!-- linha 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Comprar"
                        app:backgroundTint="@color/biblio_cyan" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="Alugar"
                        app:backgroundTint="@color/biblio_cyan" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSolicitarLivro"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="Solicitar"
                        app:backgroundTint="@color/biblio_cyan" />
                </LinearLayout>

                <!-- botão ler -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLerLivro"
                    android:layout_width="126dp"
                    android:layout_height="60dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:text="Ler"
                    app:backgroundTint="@color/biblio_cyan"
                    app:cornerRadius="40dp" />
            </LinearLayout>

            <!-- ⭐ NOTA + DISPONIBILIDADE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- esquerda -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="20dp"
                        android:text="Sua nota"
                        android:textStyle="bold" />

                    <RatingBar
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:numStars="5" />
                </LinearLayout>

                <!-- direita -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_height="50dp">

                    <TextView
                        android:text="Disponível? Sim"
                        android:layout_height="20dp"
                        android:textStyle="bold"
                        android:layout_width="105dp"/>

                    <TextView
                        android:text="Estoque: 5"
                         android:layout_height="20dp"
                         android:textStyle="bold"
                         android:layout_width="75dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 📖 SOBRE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_height="90dp">

                <TextView
                    android:text="Sobre"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_height="30dp"
                    android:layout_width="55dp"/>

                <TextView
                    android:id="@+id/txtSobreLivroDetalhe"
                    android:layout_width="100dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="4dp"
                    android:text="..." />
            </LinearLayout>

            <!-- categoria + botão -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <com.google.android.material.button.MaterialButton
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="categoria"
                    app:backgroundTint="@color/biblio_cyan" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerMaisLivro"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="Ver mais"
                    app:backgroundTint="@color/biblio_cyan" />
            </LinearLayout>

            <!-- espaço final (IMPORTANTE pro scroll) -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:text="Avaliações(0)"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
