<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#87DEDE">

            <ImageView
                android:id="@+id/imgUsuario"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_circle"
                android:padding="8dp"
                android:src="@android:drawable/sym_def_app_icon"/>

            <TextView
                android:id="@+id/tvNomeUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuário Exemplo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvEmailUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="usuario@email.com"
                android:textSize="14sp"
                android:textColor="#333333"/>

        </LinearLayout>

        <!-- BOTÕES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="542dp"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SOLICITAÇÕES -->
            <Button
                android:id="@+id/btnSolicitacoes"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#6EC1C3"
                android:text="Solicitações"
                android:textColor="#FFFFFF" />

            <!-- ALUGADOS -->
            <Button
                android:id="@+id/btnAlugados"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#6EC1C3"
                android:text="Alugados"
                android:textColor="#FFFFFF" />

            <!-- ATRASOS -->
            <Button
                android:id="@+id/btnAtrasos"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#6EC1C3"
                android:text="Atrasos de aluguéis"
                android:textColor="#FFFFFF" />

            <!-- EXCLUIR -->
            <Button
                android:id="@+id/btnExcluirConta"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="#D65252"
                android:text="Excluir conta"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>