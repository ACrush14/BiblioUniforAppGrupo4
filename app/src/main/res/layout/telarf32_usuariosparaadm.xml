<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F7">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F7F7">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#87DEDE">

                <ImageView
                    android:id="@+id/imgUsuario"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_circle"
                    android:padding="8dp"
                    android:src="@android:drawable/sym_def_app_icon"/>

                <TextView
                    android:id="@+id/tvNomeUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuário Exemplo"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvEmailUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="usuario@email.com"
                    android:textSize="14sp"
                    android:textColor="#333333"/>

            </LinearLayout>

            <!-- BOTÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="542dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- SOLICITAÇÕES -->
                <Button
                    android:id="@+id/btnSolicitacoes"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_rounded"
                    app:backgroundTint="#6EC1C3"
                    android:text="Solicitações"
                    android:textColor="#FFFFFF" />

                <!-- ALUGADOS -->
                <Button
                    android:id="@+id/btnAlugados"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_rounded"
                    app:backgroundTint="#6EC1C3"
                    android:text="Alugados"
                    android:textColor="#FFFFFF" />

                <!-- ATRASOS -->
                <Button
                    android:id="@+id/btnAtrasos"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_input_rounded"
                    app:backgroundTint="#6EC1C3"
                    android:text="Atrasos de aluguéis"
                    android:textColor="#FFFFFF" />

                <!-- EXCLUIR -->
                <Button
                    android:id="@+id/btnExcluirConta"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_input_rounded"
                    app:backgroundTint="#E53935"
                    android:text="Excluir conta"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 🔥 BARRA ADM -->
    <LinearLayout
        android:id="@+id/bottomNavigationADM"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_today"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navUsuarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#1B3434" />

        <ImageView
            android:id="@+id/navSolicitacoes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navAjuda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_help"
            app:tint="#A0A0A0" />

        <ImageView
            android:id="@+id/navLivrosADM"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#A0A0A0" />

    </LinearLayout>

</LinearLayout>